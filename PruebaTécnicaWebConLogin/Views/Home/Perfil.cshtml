@{
    ViewData["Title"] = "Perfil de Usuario";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <style>
        .form-control:disabled, .form-select:disabled {
            background-color: #f8f9fa !important;
            color: #333 !important;
        }
    </style>
</head>
<body style="background-color: #f4f6f9;">

    <div class="d-flex" style="min-height: 100vh;">

        <div class="bg-white border-end d-flex flex-column align-items-center py-4 gap-4" style="width: 70px;">
            <i class="bi bi-list fs-4 text-secondary"></i>
            <i class="bi bi-house-door fs-5 text-secondary"></i>
            <i class="bi bi-building fs-5 text-secondary"></i>
            <div class="p-2 bg-light border border-danger rounded text-danger">
                <i class="bi bi-file-earmark-person fs-5"></i>
            </div>
            <i class="bi bi-search fs-5 text-secondary"></i>
        </div>

        <div class="flex-grow-1 d-flex flex-column">

            <div class="d-flex align-items-center justify-content-between px-4 text-white" style="background-color: #990000; height: 65px;">
                <div class="fw-bold fs-5"></div>
                <div class="d-flex align-items-center gap-4">
                    <i class="bi bi-question-circle fs-5" style="cursor: pointer;"></i>
                    <div class="position-relative" style="cursor: pointer;">
                        <i class="bi bi-bell fs-5"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary" style="font-size: 0.65rem;">9+</span>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-person-circle fs-4"></i>
                            <div class="text-end lh-1">
                                <span class="small fw-semibold d-block">Osorio Montes, Adriana</span>
                                <span class="text-white-50" style="font-size: 0.75rem;">Operador</span>
                            </div>
                        </div>
                        <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-light btn-sm fw-semibold px-3 ms-2" style="border-radius: 20px; font-size: 0.8rem; border-color: rgba(255,255,255,0.6);">
                            Salir
                        </a>
                    </div>
                </div>
            </div>

            <div class="p-4 flex-grow-1">
                <span class="text-muted small d-block mb-1">Perfil de usuario</span>
                <h2 class="text-dark fw-bold mb-4" style="font-size: 1.75rem;">Perfil de usuario</h2>

                <div class="card border-0 shadow-sm p-4 bg-white mb-4" style="border-radius: 12px;">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white" style="background-color: #adc7e6; width: 80px; height: 80px;">
                            <i class="bi bi-person-fill fs-1 text-primary"></i>
                        </div>
                        <div>
                            <div class="d-flex align-items-center gap-2">
                                <h4 class="m-0 fw-bold text-dark" style="font-size: 1.35rem;">Mendoza Quispe, July Camila</h4>
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 small fw-semibold">Activo</span>
                            </div>
                            <p class="m-0 text-muted small fw-medium mt-0.5">Administrador de Recursos</p>
                            <p class="m-0 text-muted small" style="font-size: 0.8rem;">011 Ministerio de Salud</p>
                        </div>
                    </div>

                    <div class="d-flex border-bottom mb-4 gap-4" style="font-size: 0.9rem;">
                        <a href="#" class="text-decoration-none fw-bold pb-2 border-bottom border-primary border-3 text-primary">Información básica</a>
                        <a href="#" class="text-decoration-none text-muted pb-2">Responsabilidades</a>
                        <a href="#" class="text-decoration-none text-muted pb-2">Historial de responsabilidades</a>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Nombres</label>
                            <input type="text" class="form-control" value="July Camila" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Primer Apellido</label>
                            <input type="text" class="form-control" value="Mendoza" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Segundo Apellido</label>
                            <input type="text" class="form-control" value="Quispe" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Tipo de Documento de Identidad</label>
                            <input type="text" class="form-control" value="DNI" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">N° de Documento de Identidad</label>
                            <input type="text" class="form-control" value="07079879" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Fecha de nacimiento</label>
                            <input type="text" class="form-control" value="15 / 04 / 1944" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Nacionalidad</label>
                            <input type="text" class="form-control" value="Peruana" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Sexo</label>
                            <input type="text" class="form-control" value="Femenino" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Correo electrónico principal</label>
                            <div class="input-group">
                                <input type="email" class="form-control" value="test@minsa.gob.pe" disabled />
                                <span class="input-group-text bg-white"><i class="bi bi-pencil text-primary"></i></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Correo electrónico secundario (Opcional)</label>
                            <input type="email" class="form-control" value="" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Teléfono Móvil</label>
                            <div class="input-group">
                                <input type="text" class="form-control" value="+51 999 999 999" disabled />
                                <span class="input-group-text bg-white"><i class="bi bi-pencil text-primary"></i></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Teléfono secundario (Opcional)</label>
                            <div class="d-flex gap-2">
                                <select class="form-select text-muted" style="width: 100px;" disabled><option>Tipo</option></select>
                                <input type="text" class="form-control" value="" disabled />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Tipo de Contratación</label>
                            <input type="text" class="form-control" value="CAS" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label text-muted small fw-bold mb-1">Fecha de contratación</label>
                            <input type="text" class="form-control" value="09 / 03 / 2015" disabled />
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalExpiracion" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 p-3" style="border-radius: 8px;">
                <div class="modal-body text-center">
                    <div class="text-warning mb-3">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Su sesión está a punto de expirar</h5>
                    <p class="text-muted small px-3">
                        Por seguridad, su sesión expirará en <span id="lblContador" class="fw-bold text-dark">60</span> segundos. Para continuar, seleccione "Extender sesión".
                    </p>
                    <div class="mt-4">
                        <button type="button" class="btn fw-bold px-4 py-2" style="background-color: #d49a00; color: white;" onclick="extenderSesion()">Extender sesión</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        window.SessionConfig = {
            timeoutMs: 60000,
            redirectUrl: '@Url.Action("ForzarCierreInactividad", "Account")'
        };
    </script>
    <script src="~/js/session-monitor.js" asp-append-version="true"></script>
</body>
</html>