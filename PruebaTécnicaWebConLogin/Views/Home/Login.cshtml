@{
    ViewData["Title"] = "Iniciar Sesión";

    // Captura de errores desde el controlador para cambiar estilos visuales en tiempo de ejecución
    bool tieneErrorUsuario = ViewBag.ErrorUsuario != null;
    bool tieneErrorPassword = ViewBag.ErrorPassword != null;

    // Validar el método antes de intentar acceder a la colección Form
    string usuarioDigitado = Context.Request.Method == "POST" && Context.Request.HasFormContentType
        ? Context.Request.Form["username"].ToString()
        : "";

    // Captura el flag desde la cookie temporal cifrada interna del servidor
    bool mostrarAlertaExpirada = TempData["SesionExpirada"] != null && (bool)TempData["SesionExpirada"];
}

<!-- Se incluye la librería estándar de Bootstrap Icons para los nuevos vectores visuales -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

@if (mostrarAlertaExpirada)
{
    <div id="alertaExpiracion" class="position-fixed bottom-0 end-0 m-4 p-3 border-start border-primary border-4 shadow bg-white rounded d-flex align-items-center gap-3 fade show"
         style="z-index: 1060; max-width: 350px; background-color: #e6f2ff !important;">
        <i class="bi bi-info-circle-fill text-primary fs-5"></i>
        <div class="small text-dark fw-medium" style="font-family: sans-serif; line-height: 1.4;">
            Su sesión ha expirado debido a inactividad. Por favor, inicie sesión nuevamente.
        </div>
    </div>
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: calc(100vh - 144px); padding: 20px 0;">
        <div class="col-12 col-sm-10 col-md-7 col-lg-4">

            <div class="card p-4 shadow-sm border-0 bg-white mb-3" style="border-radius: 12px;">
                <div class="card-body">

                    <div class="btn-group w-100 mb-4" role="group">
                        <button type="button" class="btn btn-secondary btn-sm fw-semibold active" style="background-color: #6c757d; border: none;">DNI</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm fw-semibold" style="border-color: #ced4da; color: #6c757d;">CE</button>
                    </div>

                    <form action="@Url.Action("Login", "Account")" method="post">

                        <div class="mb-3">
                            <label for="username" class="form-label small fw-semibold text-secondary m-1">Usuario</label>
                            <div class="input-group has-validation">
                                <span class="input-group-text bg-white border-end-0 text-muted" style="border-color: @(tieneErrorUsuario ? "#dc3545" : "#ced4da");">
                                    <i class="bi bi-person-fill"></i>
                                </span>
                                <input type="text" id="username" name="username"
                                       class="form-control border-start-0 @(tieneErrorUsuario ? "is-invalid" : "")"
                                       placeholder="Ingresar usuario" required value="@usuarioDigitado" />

                                @if (tieneErrorUsuario)
                                {
                                    <div class="invalid-feedback d-block small text-danger mt-1 fw-medium">
                                        <i class="bi bi-exclamation-circle-fill"></i> @ViewBag.ErrorUsuario
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label small fw-semibold text-secondary m-1">Contraseña</label>
                            <div class="input-group has-validation">
                                <span class="input-group-text bg-white border-end-0 text-muted" style="border-color: @(tieneErrorPassword ? "#dc3545" : "#ced4da");">
                                    <i class="bi bi-lock-fill"></i>
                                </span>

                                <input type="password" id="password" name="password"
                                       class="form-control border-start-0 border-end-0 @(tieneErrorPassword ? "is-invalid" : "")"
                                       placeholder="Ingresar contraseña" required />

                                <!-- Botón del ojo con el ícono web estándar -->
                                <span id="btnRevelar" class="input-group-text bg-white border-start-0 text-muted" style="cursor: pointer; border-color: @(tieneErrorPassword ? "#dc3545" : "#ced4da"); user-select: none;">
                                    <i id="iconoOjo" class="bi bi-eye"></i>
                                </span>

                                @if (tieneErrorPassword)
                                {
                                    <div class="invalid-feedback d-block small text-danger mt-1 fw-medium">
                                        <i class="bi bi-exclamation-circle-fill"></i> @ViewBag.ErrorPassword
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="text-start mb-4">
                            <a href="#" class="text-decoration-none small fw-semibold" style="color: #0056b3; font-size: 0.85rem;">¿Olvidó su contraseña?</a>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" style="background-color: #0056b3; border: none; color: white;">
                            Ingresar
                        </button>
                    </form>

                </div>
            </div>

            <div class="card p-3 shadow-sm border-0 text-center bg-white" style="border-radius: 12px;">
                <p class="mb-0 small text-muted">
                    <i class="bi bi-headset"></i> ¿Necesita ayuda?, <a href="#" class="text-decoration-none fw-semibold" style="color: #0056b3;">contacte con el área de soporte.</a>
                </p>
            </div>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        configurarAlertaExpiracion();
        configurarAlternadorContrasena();
    });

    /**
     * Administra el desvanecimiento y destrucción automática de la notificación de inactividad.
     */
    function configurarAlertaExpiracion() {
        const alertaExpiracion = document.getElementById("alertaExpiracion");
        if (!alertaExpiracion) return;

        const TIEMPO_VISIBILIDAD_MS = 30000;
        const TIEMPO_TRANSICION_CSS_MS = 150;

        setTimeout(() => {
            alertaExpiracion.classList.remove("show");

            setTimeout(() => alertaExpiracion.remove(), TIEMPO_TRANSICION_CSS_MS);
        }, TIEMPO_VISIBILIDAD_MS);
    }

    /**
     * Inicializa los eventos del disparador para alternar la visibilidad de la contraseña.
     */
    function configurarAlternadorContrasena() {
        const campoContrasena = document.getElementById("password");
        const botonRevelar = document.getElementById("btnRevelar");

        if (!campoContrasena || !botonRevelar) return;

        botonRevelar.addEventListener("click", () => {
            const esPassword = campoContrasena.type === "password";

            campoContrasena.type = esPassword ? "text" : "password";
            actualizarIconoVisual(esPassword);
        });
    }

    /**
     * Modifica las clases de Bootstrap Icons según el estado dinámico del control.
     */
    function actualizarIconoVisual(mostrarTexto) {
        const iconoOjo = document.getElementById("iconoOjo");
        if (!iconoOjo) return;

        // Si mostrarTexto es true pasará a 'text', por ende cambiamos al ojo tachado (hide)
        iconoOjo.classList.toggle("bi-eye-slash", mostrarTexto);
        iconoOjo.classList.toggle("bi-eye", !mostrarTexto);
    }
</script>