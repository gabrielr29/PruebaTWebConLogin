@{
    ViewData["Title"] = "Cuenta Bloqueada";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: calc(100vh - 144px); padding: 20px 0;">
        <div class="col-12 col-sm-10 col-md-7 col-lg-4 d-flex justify-content-center">

            <div class="card p-5 text-center shadow-sm border-0" style="max-width: 440px; border-radius: 16px; background-color: #ffffff;">

                <div class="mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 90px; height: 90px; background-color: #E8F0FE;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="42" height="42" fill="currentColor" class="bi bi-headset" viewBox="0 0 16 16" style="color: #0056B3;">
                            <path d="M8 1a5 5 0 0 0-5 5v1h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a6 6 0 1 1 12 0v6a2.5 2.5 0 0 1-2.5 2.5H9.366a1 1 0 0 1-.866-.5l-.34-.585A.25.25 0 0 1 8.38 14H10.5A1.5 1.5 0 0 0 12 12.5V11a1 1 0 0 1 1-1h1v-1a1 1 0 0 1 1-1h1V6a5 5 0 0 0-5-5z" />
                        </svg>
                    </div>
                </div>

                <h4 class="fw-bold mb-3 text-dark" style="line-height: 1.3;">
                    Cuenta bloqueada<br>temporalmente
                </h4>

                <p class="text-muted small mb-0 px-2" style="line-height: 1.5; font-size: 0.88rem;">
                    Has excedido el número máximo de intentos fallidos (5). Por seguridad, tu cuenta ha sido bloqueada durante 15 minutos. Intenta nuevamente más tarde.
                </p>
            </div>

        </div>
    </div>
</div>